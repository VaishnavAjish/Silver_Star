{
  "name": "silverstar-grow-server",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node test_db.js",
    "debug": "node test_api.js",
    "db:indexes": "psql -h localhost -p 5433 -U postgres -d silverstar_grow -f migrations/perf_indexes.sql",
    "db:partition": "psql -h localhost -p 5433 -U postgres -d silverstar_grow -f migrations/enterprise_partitioning.sql",
    "db:refresh-mv": "psql -h localhost -p 5433 -U postgres -d silverstar_grow -c \"SELECT refresh_materialized_views();\"",
    "db:archive": "psql -h localhost -p 5433 -U postgres -d silverstar_grow -c \"SELECT archive_old_data(60);\"",
    "worker": "node services/queueWorker.js"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "chai": "^6.2.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mocha": "^11.7.6",
    "multer": "^1.4.5-lts.1",
    "otplib": "^13.4.0",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "uuid": "^14.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-prometheus": "^0.220.0",
    "@opentelemetry/instrumentation-express": "^0.68.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/instrumentation-pg": "^0.72.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "eslint": "^10.4.0",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "uuid": "$uuid"
  }
}
