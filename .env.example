# ─────────────────────────────────────────
# Silverstar Grow — Enterprise Environment
# Copy to .env and customize
# ─────────────────────────────────────────

# ── Database ──────────────────────────────
DB_HOST=192.168.1.211
DB_PORT=5433
DB_NAME=silverstar_grow
DB_USER=postgres
DB_PASSWORD=change_this
DB_SSL=false
DB_POOL_MAX=50
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=2000
DB_STATEMENT_TIMEOUT=30000
DB_LOCK_TIMEOUT=10000
DB_IDLE_TX_TIMEOUT=60000

# Read replicas (comma-separated connection strings)
# DB_REPLICA_URLS=postgres://user:pass@replica1:5432/db,postgres://user:pass@replica2:5432/db

# ── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# Maximum requests per minute (per IP)
RATE_LIMIT_MAX=500
REQUEST_TIMEOUT_MS=30000

# ── Authentication ────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-secret-string
JWT_EXPIRES_IN=24h

# ── Logging ───────────────────────────────
# Levels: ERROR=0, WARN=1, INFO=2, DEBUG=3
LOG_LEVEL=INFO
SLOW_THRESHOLD_MS=5000
SLOW_QUERY_THRESHOLD_MS=1000

# ── Performance ───────────────────────────
DASHBOARD_TTL=30
MASTER_TTL=60
CACHE_DEFAULT_TTL=30

# ── Redis (required for queue + distributed cache) ──
# REDIS_URL=redis://:password@localhost:6379

# ── Queue ─────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_PREFIX=silverstar:queue

# ── CORS ──────────────────────────────────
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# ── Observability ─────────────────────────
# OTEL_ENABLED=true
# OTEL_METRICS_PORT=9464
# OTEL_METRICS_ENDPOINT=/metrics
# OTEL_TRACE_URL=http://localhost:4318/v1/traces

# OpenTelemetry service name (auto-set)
# OTEL_SERVICE_NAME=silverstar-grow

# ── Archival ──────────────────────────────
# ARCHIVE_RETENTION_MONTHS=60
# ARCHIVE_SCHEDULE=0 3 * * 0  # cron: every Sunday 3am
