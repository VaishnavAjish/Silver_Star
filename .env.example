# ─────────────────────────────────────────────────────────────
# Silverstar Grow — Enterprise Environment Configuration
# Copy to server/.env and fill in all values before starting
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# Local / dev:
DB_HOST=192.168.1.211
DB_PORT=5433
# AWS RDS production:
# DB_HOST=silverstar-prod.xxxxxxxxxx.ap-south-1.rds.amazonaws.com
# DB_PORT=5432
DB_NAME=silverstar_grow
DB_USER=postgres
DB_PASSWORD=change_this_to_a_strong_password
# Set to true on AWS RDS (RDS uses SSL by default)
DB_SSL=false
# Set to false only if using self-signed certs; ALWAYS true on RDS
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000
DB_LOCK_TIMEOUT=10000
DB_IDLE_TX_TIMEOUT=60000

# Read replicas — comma-separated connection strings (RDS read replicas)
# DB_REPLICA_URLS=postgres://user:pass@replica1.rds.amazonaws.com:5432/silverstar_grow

# ── Server ────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# Maximum API requests per minute per IP
RATE_LIMIT_MAX=200
REQUEST_TIMEOUT_MS=30000

# ── Authentication ────────────────────────────────────────────
# REQUIRED — Generate both with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_STRING
JWT_EXPIRES_IN=8h

# ── MFA Encryption ───────────────────────────────────────────
# 32-byte key for AES-256 encryption of TOTP secrets
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_KEY
MFA_ISSUER=Silverstar Grow ERP

# ── CORS (REQUIRED in production) ────────────────────────────
# Comma-separated list of allowed origins — must match your domain exactly
CORS_ORIGIN=https://app.yourdomain.com

# ── Redis (REQUIRED for production queue / background jobs) ──
# AWS ElastiCache: rediss://user:token@cluster.cache.amazonaws.com:6379
REDIS_URL=redis://localhost:6379

# ── Queue ─────────────────────────────────────────────────────
QUEUE_CONCURRENCY=5
QUEUE_PREFIX=silverstar:queue

# ── Logging ───────────────────────────────────────────────────
# Levels: error, warn, info, debug
LOG_LEVEL=info
SLOW_THRESHOLD_MS=5000
SLOW_QUERY_THRESHOLD_MS=500

# ── Performance / Cache TTLs (seconds) ───────────────────────
DASHBOARD_TTL=30
MASTER_TTL=120
CACHE_DEFAULT_TTL=60

# ── Static File Serving ───────────────────────────────────────
# Set to true when Node serves the built React app (no separate nginx/CDN)
SERVE_STATIC=true

# ── AWS / Cloud ───────────────────────────────────────────────
# S3 bucket for file uploads / reports
# AWS_S3_BUCKET=silverstar-grow-uploads
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=          (prefer IAM Role — avoid hard-coding keys)
# AWS_SECRET_ACCESS_KEY=      (prefer IAM Role — avoid hard-coding keys)

# CloudWatch log group (if using aws-sdk logger transport)
# CLOUDWATCH_LOG_GROUP=/silverstar-grow/production
# CLOUDWATCH_LOG_STREAM=app

# ── Observability ─────────────────────────────────────────────
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=silverstar-grow
# OTEL_TRACE_URL=http://otel-collector:4318/v1/traces

# ── Archival ──────────────────────────────────────────────────
# ARCHIVE_RETENTION_MONTHS=60
# ARCHIVE_SCHEDULE=0 3 * * 0
